#!/usr/bin/env python3

# Illumos has an unzip program that chokes on our Hubris .zip archives.
# This is a quick hack to get the check and extract functions that I need.

import zipfile
import argparse
import sys

def extract_file(zip_file_path, file_name, output_path=None):
    """Extracts a specified file from a zip archive.

    Args:
        zip_file_path: The path to the zip file.
        file_name: The name of the file to extract.
        output_path: An optional path to write the extracted file to.

    Returns:
        True if successful, False if an error occurred.
    """

    try:
        with zipfile.ZipFile(zip_file_path, 'r') as zip_ref:
            try:
                if output_path:
                    zip_ref.extract(file_name, path=output_path)
                else:
                    zip_ref.extract(file_name)
            except KeyError:
                return False  # File not found
        return True  # Successful extraction
    except zipfile.BadZipFile:
        return False  # Invalid zip file

def check_file_exists(zip_file_path, file_name):
    """Checks if a file exists in a zip archive.

    Args:
        zip_file_path: The path to the zip file.
        file_name: The name of the file to check.

    Returns:
        True if the file exists, False otherwise.
    """

    with zipfile.ZipFile(zip_file_path, 'r') as zip_ref:
        return file_name in zip_ref.namelist()

def main():
    parser = argparse.ArgumentParser(description="Extract a file from a zip archive.")
    parser.add_argument("zip_file_path", help="Path to the zip file.")
    parser.add_argument("file_name", help="Name of the file to extract.")
    parser.add_argument("--output", "-o", help="Optional path to write the extracted file to.")
    parser.add_argument("--check", action="store_true", help="Only check if the file exists, don't extract.")
    args = parser.parse_args()

    success = extract_file(args.zip_file_path, args.file_name, args.output)

    if args.check:
        if check_file_exists(args.zip_file_path, args.file_name):
            print("File exists.")
            sys.exit(0)  # File exists
        else:
            print("File not found.")
            sys.exit(1)  # File not found
    else:
        if success:
            print("File extracted successfully.")
            sys.exit(0)  # File exists
        else:
            print("Error extracting file.")
            sys.exit(1)  # File not found

if __name__ == "__main__":
    main()
